rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Collection Rules - Allow fully for registration and profiles
    match /users/{userId} {
      allow read, write: if true;
    }

    // Report Collection Rules - Allow fully for anonymous and registered citizen/staff reporting
    match /reports/{reportId} {
      allow read, write: if true;
    }

    // Community Drives Collection Rules
    match /community_drives/{driveId} {
      allow read, write: if true;
    }

    match /community_drives/{driveId}/messages/{messageId} {
      allow read, write: if true;
    }

    // Test Collection Rules
    match /test/{testId} {
      allow read, write: if true;
    }

    // Notification Collection Rules - Allow fully for alert tracking
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
  }
}
